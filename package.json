{
  "name": "plataforma-jec-mvp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "check:encoding": "node scripts/check-encoding.mjs apps/api/src apps/web/src",
    "build": "npm run check:encoding && npm run build --workspaces",
    "test": "npm run check:encoding && npm run test --workspace apps/api",
    "check:web-env": "npm run check:env --workspace apps/web",
    "check:live": "npm run check:live --workspace apps/web --"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
